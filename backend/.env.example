# Copy this file to  backend/.env  and fill in real values.
# The backend loads it at startup (see src/main.ts).
#
# IMPORTANT: put real values in .env (gitignored), NOT here — this file is a
# template and may be committed. Never put your real password in .env.example.

# ── Email (SMTP) — used to send an employee their access code ─────────────────
# Easiest option is a Gmail account with an "App Password" (needs 2-Step
# Verification enabled): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false            # true only if you use port 465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Check-N <your-gmail@gmail.com>

# ── App download link included in the invite email ───────────────────────────
# e.g. a Play Store URL, or a public link to the APK (Google Drive, Firebase
# Hosting, etc.). Leave blank to omit the download line from the email.
APP_DOWNLOAD_URL=https://example.com/download-check-n
