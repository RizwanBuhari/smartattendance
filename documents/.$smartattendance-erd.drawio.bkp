          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= legend ================= -->
        <mxCell id="legend" value="Notes&#10;• PK = document id (bold + underlined).  FK / references are italic.&#10;• admins authenticate by email (Firebase Auth); not FK-linked to employees.&#10;• employee ⇄ locations is many-to-many, stored as an array on the employee doc.&#10;• attendance.employeeId and locationPings.employeeId hold either the employee doc id OR the Firebase authUid.&#10;• *Name / *locationName fields are denormalized copies kept for display." style="text;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="380" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
